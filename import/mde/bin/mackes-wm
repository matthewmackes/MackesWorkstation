#!/usr/bin/bash
# mackes-wm — i3 helper.
#
# Phase 8.8 (1.0.7): i3 is the only window manager. This script used
# to switch between xfwm4 and i3; that mode is retired. The remaining
# verbs are:
#
#   mackes-wm status   → print the running WM's name from wmctrl -m.
#   mackes-wm reset    → rebuild ~/.config/i3/config from the shipped
#                        default at /usr/share/mackes-shell/i3/config.
#                        Backs up any existing user config to
#                        ~/.config/i3/config.bak first.
#
# Legacy verbs (`i3`, `xfwm4`) print a deprecation note. The `i3` verb
# remains a no-op success (we're already on i3); the `xfwm4` verb
# exits 1 with the deprecation note.
#
# Run from the active X11 session; no root required.

set -euo pipefail

# v2.0.0 Phase D.7 — retirement guard. When the MDE Wayland
# session is active, this v1.x i3-management script is meaningless
# (sway owns the WM role + the keybinds are reloaded via swayipc
# by the Phase C.8 keybinds applier, not by editing
# ~/.config/i3/config). The script short-circuits with a
# pointer to the new path.
if [ "${XDG_CURRENT_DESKTOP:-}" = "MDE" ] \
   || [ -n "${SWAYSOCK:-}" ]; then
    echo "mackes-wm: MDE / sway session detected — this script is retired." >&2
    echo "mackes-wm:   * For sway WM status: 'swaymsg -t get_version'" >&2
    echo "mackes-wm:   * For keybinds:       edit settings in Workbench → System → Keyboard" >&2
    echo "mackes-wm:   * For session info:   'systemctl --user status mde-session.service'" >&2
    exit 0
fi

DEFAULT_I3_CONFIG=/usr/share/mackes-shell/i3/config
USER_I3_CONFIG="$HOME/.config/i3/config"

current_wm() {
    wmctrl -m 2>/dev/null | awk -F': *' '$1=="Name"{print $2}' | head -1
}

reset_i3_config() {
    if [ ! -f "$DEFAULT_I3_CONFIG" ]; then
        echo "mackes-wm: default config $DEFAULT_I3_CONFIG missing" >&2
        echo "mackes-wm: reinstall mackes-xfce-workstation" >&2
        exit 2
    fi
    mkdir -p "$(dirname "$USER_I3_CONFIG")"
    if [ -f "$USER_I3_CONFIG" ]; then
        cp "$USER_I3_CONFIG" "$USER_I3_CONFIG.bak"
        echo "mackes-wm: backed up existing config to $USER_I3_CONFIG.bak" >&2
    fi
    cp "$DEFAULT_I3_CONFIG" "$USER_I3_CONFIG"
    echo "mackes-wm: reset $USER_I3_CONFIG from $DEFAULT_I3_CONFIG" >&2
    if command -v i3-msg >/dev/null 2>&1; then
        i3-msg reload >/dev/null 2>&1 || true
        echo "mackes-wm: reloaded i3" >&2
    fi
}

case "${1:-status}" in
    status)
        wm="$(current_wm)"
        if [ -z "$wm" ]; then
            echo "no WM detected (wmctrl unreachable)"
            exit 1
        fi
        echo "$wm"
        ;;
    reset)
        reset_i3_config
        ;;
    session-pick)
        # Phase W7 — Wayland-session-pick flow. mackes-wm can't
        # live-swap a Wayland compositor (the compositor IS the
        # display server). Instead surface every installed Wayland
        # session .desktop so the operator can pick one at the
        # greeter on next login.
        echo "Installed sessions under /usr/share/wayland-sessions/:"
        if [ -d /usr/share/wayland-sessions ]; then
            ls /usr/share/wayland-sessions/*.desktop 2>/dev/null \
                | sed 's|.*/||; s|.desktop$||' \
                | awk '{print "  " $0}'
        else
            echo "  (no Wayland sessions installed)"
        fi
        echo "Installed sessions under /usr/share/xsessions/:"
        if [ -d /usr/share/xsessions ]; then
            ls /usr/share/xsessions/*.desktop 2>/dev/null \
                | sed 's|.*/||; s|.desktop$||' \
                | awk '{print "  " $0}'
        else
            echo "  (no X11 sessions installed)"
        fi
        echo ""
        echo "To switch: log out + pick from the greeter's session dropdown."
        ;;
    probe-wayland)
        # Phase W8 — runtime probe. Reports which Wayland features
        # would be reachable on the active session without spawning
        # the full panel.
        echo "Session type:       ${XDG_SESSION_TYPE:-unknown}"
        echo "Wayland display:    ${WAYLAND_DISPLAY:-unset}"
        echo "X display:          ${DISPLAY:-unset}"
        if [ "${XDG_SESSION_TYPE:-}" = "wayland" ]; then
            echo "Layer shell:        $(command -v wayland-info >/dev/null 2>&1 && \
                wayland-info 2>/dev/null | grep -q wlr_layer_shell && \
                echo 'available' || echo 'compositor-dependent')"
        else
            echo "Layer shell:        n/a (X11 session)"
        fi
        ;;
    i3)
        # Deprecated — i3 is the only WM as of 1.0.7. Exit 0 as a
        # courtesy for any caller that previously invoked this verb
        # to ensure i3 was active.
        echo "mackes-wm: 'i3' verb is deprecated — i3 is the only WM as of 1.0.7" >&2
        ;;
    xfwm4)
        echo "mackes-wm: 'xfwm4' verb is no longer supported as of 1.0.7" >&2
        echo "mackes-wm: i3 fully replaced xfwm4; xfwm4 is no longer installed" >&2
        exit 1
        ;;
    *)
        echo "usage: $0 {status|reset|session-pick|probe-wayland}" >&2
        echo "  status         print the running WM's name" >&2
        echo "  reset          rebuild ~/.config/i3/config from the shipped default" >&2
        echo "  session-pick   list available Wayland + X11 sessions (Phase W7)" >&2
        echo "  probe-wayland  report Wayland feature reachability (Phase W8)" >&2
        exit 2
        ;;
esac
