[Xfce Panel]
Type=X-XFCE-PanelPlugin
Encoding=UTF-8
Name=Mackes Launcher
Comment=Click to open the Mackes Shell slide-out popover (Super+M)
Icon=mackes-shell
# xfce4-panel 4.20 requires X-XFCE-API=2.0; absent it defaults to
# v1.0 (Gtk2) and refuses to load. Same fix as mackes-clipboard.
X-XFCE-API=2.0
X-XFCE-Internal=false
X-XFCE-Exec=/usr/lib/xfce4/panel/plugins/mackes-launcher
X-XFCE-Module-Path=
