[Desktop Entry]
# E6.1 — the MDE Workbench as the "Manage Your Server"-style role
# console: a left-nav of role cards (Apps / Devices / Fleet / Look &
# Feel / Maintain / System / Help) each with task action-links. Opens
# at the Dashboard role via `--page dashboard`; the Win10 Start seeds a
# matching "Manage Workstation" tile (see state::seed_start_tiles).
Type=Application
Name=Manage Workstation
GenericName=Workbench
Comment=Administer the workstation from one task-oriented role console
Exec=mde-workbench --page dashboard
Icon=mackes-shell
Terminal=false
Categories=Settings;System;DesktopSettings;
Keywords=manage;workstation;workbench;console;roles;settings;control;mde;mackes;
StartupNotify=true
StartupWMClass=mde-workbench
