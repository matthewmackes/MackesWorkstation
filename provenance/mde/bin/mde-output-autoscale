#!/usr/bin/env python3
"""mde-output-autoscale — apply sane default scale per output on session start.

v2.0.3 hotfix (operator-verification 2026-05-22) — the bench machine ran
sway with eDP-1 1366×768 and DP-2 3840×2160 both at `scale = 1.0`. UI
elements on the 4K TV were unreadable across a living-room viewing
distance.

This script reads `swaymsg -t get_outputs`, picks a scale per output
using a width-based heuristic, and applies the result via
`swaymsg output <name> scale <value>` — *only* if the operator has not
overridden the scale themselves (current `scale != 1.0` is treated as
intentional and left alone).

Wired into the session via a `exec_always` line in `data/sway/config`:

    exec_always /usr/bin/mde-output-autoscale

Idempotent: re-running is a no-op (the override-respecting check above
prevents fights with manual `swaymsg output … scale …` invocations).

Heuristic:

  * width ≥ 3840 → scale 2.0  (4K and wider)
  * width ≥ 2560 → scale 1.5  (1440p / 2K)
  * width ≥ 1920 → scale 1.0  (1080p)
  * width  < 1920 → scale 1.0  (don't shrink already-small displays)

Future work (separate worklist task): EDID-aware physical-size
adjustment so a 27" 4K monitor uses scale 1.5 (high DPI but viewer
~60 cm away) while a 40"+ 4K TV uses scale 2.0 (sofa distance).

Exit codes:
  0  every scale call succeeded (or no changes were needed)
  1  swaymsg invocation failed
  2  malformed swaymsg JSON
"""
from __future__ import annotations

import json
import shutil
import subprocess
import sys
from typing import Iterable


def pick_scale(
    width: int,
    physical_width_mm: int | None = None,
    physical_height_mm: int | None = None,
) -> float:
    """Return the heuristic scale for an output of the given pixel + physical size.

    v2.1 EDID-aware refinement: when sway reports physical dimensions on
    a 4K output, the scale split between desktop monitor (closer
    viewing) and TV (sofa distance) is decided by the diagonal:

      * 4K @ diagonal ≤ 32" → scale 1.5 (high-DPI monitor, ~60 cm away)
      * 4K @ diagonal > 32" → scale 2.0 (TV, sofa distance)

    A monitor without physical dimensions falls back to the width-only
    heuristic (1.5 for ≥ 2560, 2.0 for ≥ 3840).

    Branches sorted by typical bench-rig coverage: 4K first, then 2K,
    then everything 1080p and below.
    """
    diagonal_in = _diagonal_inches(physical_width_mm, physical_height_mm)
    if width >= 3840:
        # EDID-aware split when we know the physical size.
        if diagonal_in is not None and diagonal_in > 32.0:
            return 2.0  # 40"+ TV — sofa distance
        if diagonal_in is not None:
            return 1.5  # 27"-32" 4K monitor — desk distance
        # Unknown physical size; legacy width-only fallback.
        return 2.0
    if width >= 2560:
        return 1.5
    return 1.0


def _diagonal_inches(width_mm: int | None, height_mm: int | None) -> float | None:
    """Compute the panel diagonal in inches from sway's `physical_width`
    + `physical_height`. Returns None when either is missing / zero /
    negative (sway reports 0 for outputs whose EDID didn't carry the
    fields).
    """
    if not isinstance(width_mm, int) or width_mm <= 0:
        return None
    if not isinstance(height_mm, int) or height_mm <= 0:
        return None
    diagonal_mm = (width_mm * width_mm + height_mm * height_mm) ** 0.5
    return diagonal_mm / 25.4


def get_outputs() -> list[dict]:
    """Invoke `swaymsg -t get_outputs` and return the parsed JSON list.

    Raises SystemExit on swaymsg invocation / parse failure so callers
    don't have to defensively wrap every call.
    """
    if shutil.which("swaymsg") is None:
        print("mde-output-autoscale: swaymsg not on $PATH — not in a sway session?", file=sys.stderr)
        raise SystemExit(1)
    try:
        result = subprocess.run(
            ["swaymsg", "-t", "get_outputs"],
            check=True, capture_output=True, text=True, timeout=5,
        )
    except (subprocess.CalledProcessError, subprocess.TimeoutExpired, OSError) as exc:
        print(f"mde-output-autoscale: swaymsg failed: {exc}", file=sys.stderr)
        raise SystemExit(1) from exc
    try:
        outputs = json.loads(result.stdout)
    except json.JSONDecodeError as exc:
        print(f"mde-output-autoscale: swaymsg JSON parse error: {exc}", file=sys.stderr)
        raise SystemExit(2) from exc
    if not isinstance(outputs, list):
        print("mde-output-autoscale: swaymsg returned non-list", file=sys.stderr)
        raise SystemExit(2)
    return outputs


def plan_scales(outputs: Iterable[dict]) -> list[tuple[str, float]]:
    """Walk the output list and emit (name, desired_scale) tuples for
    every output whose current scale is exactly 1.0 (the sway default).

    Operator-set scales (current != 1.0) are treated as intentional and
    skipped so this helper never fights a manual tweak.
    """
    plan: list[tuple[str, float]] = []
    for out in outputs:
        name = out.get("name") or ""
        if not name:
            continue
        if not out.get("active", False):
            continue
        mode = out.get("current_mode") or {}
        width = mode.get("width")
        if not isinstance(width, int) or width <= 0:
            continue
        current_scale = out.get("scale")
        if not isinstance(current_scale, (int, float)):
            continue
        # Operator override — leave it alone.
        if abs(float(current_scale) - 1.0) > 1e-6:
            continue
        # v2.1 EDID-aware split: sway >=1.8 surfaces `physical_width`
        # + `physical_height` in mm on outputs whose EDID carries the
        # fields. When present, pick_scale uses the diagonal to
        # choose between 1.5 (desk-distance monitor) and 2.0 (sofa-
        # distance TV) on the 4K branch.
        physical_w = out.get("physical_width") if isinstance(out.get("physical_width"), int) else None
        physical_h = out.get("physical_height") if isinstance(out.get("physical_height"), int) else None
        desired = pick_scale(width, physical_w, physical_h)
        if abs(desired - 1.0) <= 1e-6:
            # Heuristic says "leave at 1.0" — nothing to do.
            continue
        plan.append((name, desired))
    return plan


def apply_scale(name: str, scale: float) -> bool:
    """Run `swaymsg output <name> scale <scale>` and return success."""
    try:
        subprocess.run(
            ["swaymsg", "output", name, "scale", f"{scale}"],
            check=True, timeout=5,
            stdout=subprocess.DEVNULL, stderr=subprocess.PIPE, text=True,
        )
        return True
    except subprocess.CalledProcessError as exc:
        print(f"mde-output-autoscale: swaymsg output {name} scale {scale} failed: {exc.stderr.strip()}", file=sys.stderr)
        return False
    except (subprocess.TimeoutExpired, OSError) as exc:
        print(f"mde-output-autoscale: swaymsg output {name} scale {scale} errored: {exc}", file=sys.stderr)
        return False


def main(argv: list[str] | None = None) -> int:
    _ = argv  # CLI flags are reserved for future use (`--dry-run`, `--force`).
    outputs = get_outputs()
    plan = plan_scales(outputs)
    if not plan:
        return 0
    failures = 0
    for name, scale in plan:
        if not apply_scale(name, scale):
            failures += 1
        else:
            print(f"mde-output-autoscale: {name} scale {scale}")
    return 1 if failures else 0


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
