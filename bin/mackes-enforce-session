#!/usr/bin/bash
# mackes-enforce-session — make sure every login lands on i3 with no
# xfce4-panel / xfdesktop running.
#
# Phase 8.8 (1.0.7+): xfwm4 is fully replaced by i3, and mackes-panel
# replaces xfce4-panel + xfdesktop. The XFCE session host (xfce4-session)
# still owns process supervision and starts whatever it was told to start
# by `/etc/xdg/xfce4/xfconf/xfce-perchannel-xml/xfce4-session.xml` — on a
# stock Fedora install that's `xfwm4` + `xfce4-panel` + `xfdesktop`. This
# script runs from `/etc/xdg/autostart/mackes-enforce-session.desktop`
# (priority 50, after the session has spawned all Failsafe clients) and
# converges the live process tree onto the Mackes target state.
#
# Idempotent: re-running is a no-op if the system is already in the
# target state. Failures are non-fatal — we log to stderr and exit 0 so
# the XDG-autostart slot never shows a "failed" notification.

set -u

log() {
    echo "mackes-enforce-session: $*" >&2
}

# 1. WM: if i3 isn't already the live WM, run `i3 --replace` to take
#    over via the WM-replace protocol (xfwm4 exits cleanly when it
#    sees the replace signal).
if command -v i3 >/dev/null 2>&1; then
    current_wm="$(wmctrl -m 2>/dev/null | awk -F': *' '$1=="Name"{print $2}' | head -1 || true)"
    if [ "${current_wm:-}" != "i3" ]; then
        i3 --replace >/dev/null 2>&1 &
        disown
        log "started i3 --replace (was: ${current_wm:-unknown})"
    fi
else
    log "i3 binary not found — reinstall mackes-xfce-workstation"
fi

# 2. Panel: kill xfce4-panel if it's running. mackes-panel is started
#    by its own autostart entry (priority 50 too — order within the
#    same priority is implementation-defined, so the panel may briefly
#    coexist with xfce4-panel; that's why this step is idempotent and
#    runs on every session).
if pgrep -x xfce4-panel >/dev/null 2>&1; then
    xfce4-panel --quit >/dev/null 2>&1 || pkill -x xfce4-panel >/dev/null 2>&1 || true
    log "stopped xfce4-panel"
fi

# 3. Desktop: kill xfdesktop. mackes-panel owns the wallpaper + root
#    window roles. We ship a Hidden=true autostart override for
#    xfdesktop, but that doesn't help if xfce4-session spawned it from
#    its own client list rather than via XDG-autostart.
if pgrep -x xfdesktop >/dev/null 2>&1; then
    xfdesktop --quit >/dev/null 2>&1 || pkill -x xfdesktop >/dev/null 2>&1 || true
    log "stopped xfdesktop"
fi

# 4. Make sure mackes-panel is alive (defense-in-depth — its own
#    autostart entry usually handles this, but if the user killed it
#    or a previous run errored out we want it back).
if ! pgrep -x mackes-panel >/dev/null 2>&1; then
    if command -v mackes-panel >/dev/null 2>&1; then
        nohup mackes-panel >/dev/null 2>&1 &
        disown
        log "started mackes-panel"
    fi
fi

# 5a. 1.1.0 — make sure the user units Mackes ships are enabled for the
#     current user. The systemd-preset at /usr/lib/systemd/user-preset/
#     90-mackes.preset handles new accounts; this loop handles existing
#     accounts. `systemctl --user is-enabled` is cheap (parses the
#     symlink), and `enable --now` is idempotent when the unit is
#     already enabled + running.
for unit in \
    mackes-clipboard-daemon.service \
    mackes-gvfsd-mesh.service \
    mackes-remmina-sync.timer \
    mackes-media-sync.timer
do
    if ! systemctl --user is-enabled "$unit" >/dev/null 2>&1; then
        systemctl --user enable --now "$unit" >/dev/null 2>&1 || true
        log "enabled user unit $unit"
    fi
done

# 5b. 1.1.0 — propagate XFCE menu hides into the current user's home.
#    /etc/skel only seeds NEW accounts; existing users won't pick up
#    the hide-xfce-settings.sh additions unless we copy them here on
#    login. Idempotent: skip when the user's copy already exists
#    AND already carries the Mackes-Hidden marker (so a user who
#    deliberately edited the file isn't clobbered).
SKEL_APPS=/etc/skel/.local/share/applications
USER_APPS="$HOME/.local/share/applications"
if [ -d "$SKEL_APPS" ]; then
    mkdir -p "$USER_APPS"
    propagated=0
    for src in "$SKEL_APPS"/*.desktop; do
        [ -f "$src" ] || continue
        grep -q "X-Mackes-Hidden=1" "$src" || continue
        dst="$USER_APPS/$(basename "$src")"
        if [ -f "$dst" ]; then
            grep -q "X-Mackes-Hidden=1" "$dst" && continue
            # User has their own override (no Mackes marker) — leave it.
            continue
        fi
        cp -f "$src" "$dst"
        propagated=$((propagated + 1))
    done
    if [ "$propagated" -gt 0 ]; then
        log "propagated $propagated hidden-menu overrides to $USER_APPS"
    fi
fi

exit 0
