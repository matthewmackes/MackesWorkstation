# Files to ship in the sdist (the source tarball consumed by rpmbuild).
# These aren't packaged into the Python wheel — the .spec file installs
# them into /usr/share/mackes-shell/ at RPM build time.

include LICENSE
include README.md
include CHANGELOG.md
include Makefile
include install.sh
include uninstall.sh
include pyproject.toml
include setup.py

# Rust workspace — root manifest + lock + every crate (Phase 0.1-0.3)
include Cargo.toml
include Cargo.lock
include rust-toolchain.toml
recursive-include crates *.toml *.rs *.sql

# Branding (logo placed on About, Wizard welcome, and Dashboard header +
# the standard wallpaper used for desktop + LightDM greeter + boot
# splash MP4 played before the wizard surfaces)
recursive-include branding *.png *.svg *.mp4 *.webm

# Specs and CI
recursive-include packaging *
recursive-include install-helpers *.sh
recursive-include .github *.yml

# Documentation (top-level spec + per-feature help topics)
recursive-include docs *.md

# bin/ wrappers consumed by the spec's %%install — mackes-gvfsd-mesh,
# mackes-mesh-open
recursive-include bin *

# C panel plugin sources (compiled in %%build before %%install)
recursive-include data/panel-plugins *

# Shipped data tree: presets, wallpapers, applications/.desktop, icons,
# CSS tokens, dnf repo file, systemd units, grub snippets, mesh-services
# catalog, Carbon icon theme + PadOS GTK theme, captured xfce-baseline
recursive-include data *

# Explicit include for data/applications/mackes-panel.desktop in case
# the recursive pattern misses dot-extensions on some Python builds.
include data/applications/mackes-panel.desktop

# Tests (shipped so downstream rebuilds can run them)
recursive-include tests *.py
